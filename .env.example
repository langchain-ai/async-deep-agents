# LLM Provider (pick one or more depending on your agents)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# LangSmith (required for LangGraph Platform deployments)
LANGSMITH_API_KEY=your-langsmith-api-key

# Optional: LangGraph API URL (only needed for remote deployments)
# LANGGRAPH_API_URL=https://your-deployment.langsmith.dev
